{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/sipc/schemas/common_defs.schema.json",
  "title": "SIPC Common Definitions",
  "description": "Définitions, enums et fragments réutilisables pour l’ontologie JSON V1 de la Sociologie Internationale des Personnes Collectives.",
  "$defs": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.\\d+(\\.\\d+)?$"
    },
    "object_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 160,
      "pattern": "^[A-Z0-9_:\\-.]+$"
    },
    "free_text": {
      "type": "string",
      "minLength": 1
    },
    "nullable_text": {
      "type": [
        "string",
        "null"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "score_0_1": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "confidence_label": {
      "type": "string",
      "enum": [
        "LOW",
        "MEDIUM_LOW",
        "MEDIUM",
        "MEDIUM_HIGH",
        "HIGH"
      ]
    },
    "evidence_status": {
      "type": "string",
      "enum": [
        "SPECULATIVE",
        "WEAKLY_SUPPORTED",
        "MODERATELY_SUPPORTED",
        "STRONGLY_SUPPORTED",
        "CONTESTED",
        "DISCONFIRMED",
        "INSUFFICIENT_EVIDENCE"
      ]
    },
    "analytical_status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "REVIEW_REQUIRED",
        "VALIDATED",
        "CONTESTED",
        "ARCHIVED"
      ]
    },
    "field_code": {
      "type": "string",
      "enum": [
        "MIL",
        "DIP",
        "ECO",
        "FIN",
        "TEC",
        "LEGAL",
        "INST",
        "SYM",
        "INF",
        "HUM",
        "ENV",
        "SOC",
        "COG",
        "LOG",
        "ENERGY",
        "OTHER"
      ]
    },
    "actor_type": {
      "type": "string",
      "enum": [
        "STATE",
        "SUBSTATE_ACTOR",
        "INTERNATIONAL_ORGANIZATION",
        "REGIONAL_ORGANIZATION",
        "MULTINATIONAL_FIRM",
        "PLATFORM",
        "NGO",
        "ARMED_GROUP",
        "TERRORIST_GROUP",
        "DIASPORA",
        "EXPERT_COMMUNITY",
        "FINANCIAL_INSTITUTION",
        "INFORMAL_COALITION",
        "CRIMINAL_NETWORK",
        "INDIVIDUAL_LEADER",
        "OTHER"
      ]
    },
    "relation_type": {
      "type": "string",
      "enum": [
        "ALLIANCE",
        "RIVALRY",
        "DEPENDENCY",
        "PROTECTION",
        "COERCION",
        "COMPETITION",
        "COOPERATION",
        "DOMINATION",
        "CONTESTATION",
        "MEDIATION",
        "RECOGNITION",
        "NON_RECOGNITION",
        "SANCTION",
        "TRADE",
        "FINANCIAL_EXPOSURE",
        "TECHNOLOGICAL_INTEGRATION",
        "INFORMATION_INFLUENCE",
        "LEGAL_DISPUTE",
        "OTHER"
      ]
    },
    "capital_type": {
      "type": "string",
      "enum": [
        "MILITARY",
        "ECONOMIC",
        "FINANCIAL",
        "TECHNOLOGICAL",
        "LEGAL",
        "INSTITUTIONAL",
        "SYMBOLIC",
        "INFORMATIONAL",
        "HUMANITARIAN",
        "LOGISTICAL",
        "ENERGY",
        "COGNITIVE",
        "NORMATIVE",
        "SOCIAL",
        "OTHER"
      ]
    },
    "mechanism_type": {
      "type": "string",
      "enum": [
        "CAPITAL_CONVERSION",
        "DEPENDENCY_WEAPONIZATION",
        "AUDIENCE_LOCK_IN",
        "RECOGNITION_CRISIS",
        "SECURITY_DILEMMA",
        "NORM_ACTIVATION",
        "CLASSIFICATION_STRUGGLE",
        "CREDIBILITY_GAP",
        "SELF_FULFILLING_PROPHECY",
        "ORDER_DESYNCHRONIZATION",
        "HEGEMONIC_CONTESTATION",
        "RESILIENCE_TEST",
        "INSTITUTIONAL_BLOCKAGE",
        "OTHER"
      ]
    },
    "trajectory_type": {
      "type": "string",
      "enum": [
        "ESCALATION",
        "DEESCALATION",
        "STABILIZATION",
        "FREEZE",
        "INSTITUTIONALIZATION",
        "NORMALIZATION",
        "FRAGMENTATION",
        "DISPLACEMENT",
        "RADICALIZATION",
        "ORDER_TRANSFORMATION",
        "CONTAINMENT",
        "CONTESTATION",
        "REFORM",
        "PARTIAL_COLLAPSE",
        "OTHER"
      ]
    },
    "situation_type": {
      "type": "string",
      "enum": [
        "SECURITY_TENSION",
        "RECOGNITION_CONFLICT",
        "TECHNOLOGY_DEPENDENCY",
        "ENERGY_DEPENDENCY",
        "FINANCIAL_STRESS",
        "HUMANITARIAN_CRISIS",
        "INSTITUTIONAL_CRISIS",
        "NORMATIVE_CONFLICT",
        "REGIONAL_ORDER_STRESS",
        "HEGEMONIC_CONTESTATION",
        "CRISIS",
        "LATENT_TENSION",
        "ORDER_TRANSITION",
        "OTHER"
      ]
    },
    "norm_family": {
      "type": "string",
      "enum": [
        "SOVEREIGNTY",
        "SECURITY",
        "HUMANITARIAN",
        "HUMAN_RIGHTS",
        "ECONOMIC",
        "FINANCIAL",
        "ENVIRONMENTAL",
        "TECHNOLOGICAL",
        "INSTITUTIONAL",
        "SYMBOLIC_STATUS",
        "OTHER"
      ]
    },
    "institution_type": {
      "type": "string",
      "enum": [
        "FORMAL_ORGANIZATION",
        "INTERNATIONAL_REGIME",
        "POWER_CLUB",
        "LEGAL_INSTITUTION",
        "FINANCIAL_INSTITUTION",
        "TECHNICAL_STANDARD_BODY",
        "MARKET_INSTITUTION",
        "SECURITY_INSTITUTION",
        "INFORMAL_FORUM",
        "DISCURSIVE_INSTITUTION",
        "OTHER"
      ]
    },
    "dependency_type": {
      "type": "string",
      "enum": [
        "SECURITY",
        "ENERGY",
        "TECHNOLOGICAL",
        "FINANCIAL",
        "LOGISTICAL",
        "FOOD",
        "INDUSTRIAL",
        "LEGAL",
        "INFORMATIONAL",
        "INSTITUTIONAL",
        "OTHER"
      ]
    },
    "evidence_type": {
      "type": "string",
      "enum": [
        "OFFICIAL_DISCOURSE",
        "DOCTRINAL_DOCUMENT",
        "OBSERVABLE_PRACTICE",
        "MATERIAL_DATA",
        "SEQUENCE_TIMING",
        "AUDIENCE_REACTION",
        "SOURCE_DOCUMENT",
        "COUNTER_EVIDENCE",
        "EXPERT_ASSESSMENT",
        "UNKNOWN",
        "OTHER"
      ]
    },
    "source_reliability": {
      "type": "string",
      "enum": [
        "LOW",
        "MEDIUM_LOW",
        "MEDIUM",
        "MEDIUM_HIGH",
        "HIGH",
        "UNKNOWN"
      ]
    },
    "probability_band": {
      "type": "string",
      "enum": [
        "LOW",
        "MEDIUM_LOW",
        "MEDIUM",
        "MEDIUM_HIGH",
        "HIGH",
        "UNKNOWN"
      ]
    },
    "string_array": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "field_activation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "intensity",
        "role_in_situation"
      ],
      "properties": {
        "field": {
          "$ref": "#/$defs/field_code"
        },
        "intensity": {
          "$ref": "#/$defs/score_0_1"
        },
        "role_in_situation": {
          "type": "string"
        }
      }
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "summary",
        "strength",
        "reliability"
      ],
      "properties": {
        "evidence_id": {
          "$ref": "#/$defs/object_id"
        },
        "source_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/object_id"
          },
          "default": []
        },
        "summary": {
          "type": "string"
        },
        "strength": {
          "$ref": "#/$defs/score_0_1"
        },
        "reliability": {
          "$ref": "#/$defs/score_0_1"
        }
      }
    },
    "invalidation_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal",
        "why_it_matters"
      ],
      "properties": {
        "signal": {
          "type": "string"
        },
        "why_it_matters": {
          "type": "string"
        },
        "monitoring_indicators": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    }
  }
}
